SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase Storage 버킷 이름 (결과 저장용, 기본값: separated-audio)
SUPABASE_BUCKET=separated-audio

# Next.js가 올려주는 원본 파일을 받는 버킷 (기본값: stem-uploads)
SUPABASE_UPLOAD_BUCKET=stem-uploads

# 서버 포트
PORT=5174

# Cloudflare Tunnel로 외부에 노출되므로, 요청 인증용 API 키를 설정 권장
# 설정 시 모든 요청에 헤더 X-API-Key: <값> 이 필요함 (비워두면 인증 없이 개방)
API_KEY=

# cloudflared 실행파일 경로 (기본값: ./cloudflared/cloudflared.exe)
CLOUDFLARED_PATH=

# m4a 등 soundfile이 못 읽는 포맷 디코딩용 FFmpeg 폴더
# winget install --id Gyan.FFmpeg 로 설치 후 <설치경로>\bin 을 지정
FFMPEG_DIR=
